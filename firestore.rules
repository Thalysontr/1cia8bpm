rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()        { return request.auth != null; }
    function isAdmin()       { return isAuth() && request.auth.token.role == 'admin'; }
    function isColaborador() { return isAuth() && request.auth.token.role == 'colaborador'; }
    function isUser()        { return isAdmin() || isColaborador(); }

    // Militares: leitura autenticada, escrita só admin
    match /mils/{docId} {
      allow read: if isUser();
      allow write: if isAdmin();
    }

    // Operações: leitura e criação para todos, exclusão só admin
    match /ops/{docId} {
      allow read:   if isUser();
      allow create: if isUser();
      allow update: if isUser();
      allow delete: if isAdmin();
    }

    // Escalas: leitura e criação para todos, exclusão só admin
    match /escalas/{docId} {
      allow read:   if isUser();
      allow create: if isUser();
      allow update: if isUser();
      allow delete: if isAdmin();
    }

    // Dispensas: leitura e escrita para todos autenticados
    match /dispensas/{docId} {
      allow read:  if isUser();
      allow write: if isUser();
    }

    // Rate limiting de login (escrito antes da autenticação — acesso público restrito)
    match /rateLimits/{docId} {
      allow read, write: if true;
    }

    // Logs de autenticação — só leitura admin, escrita qualquer autenticado
    match /logs/{docId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }

    // Config geral: vrte e anexo_visitas para usuários autenticados
    match /config/vrte {
      allow read:  if isUser();
      allow write: if isUser();
    }

    match /config/anexo_visitas {
      allow read:  if isUser();
      allow write: if isAdmin();
    }

    // Usuários e assinantes: só admin
    match /config/usuarios    { allow read, write: if isAdmin(); }
    match /config/assinantes  { allow read, write: if isAdmin(); }
    match /config/ultimo_assinante { allow read: if isUser(); allow write: if isAdmin(); }

    // Bloquear tudo que não foi explicitamente liberado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
