rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()        { return request.auth != null; }
    function isAdmin()       { return isAuth() && request.auth.token.role == 'admin'; }
    function isColaborador() { return isAuth() && request.auth.token.role == 'colaborador'; }
    function isUser()        { return isAdmin() || isColaborador(); }

    // Multi-tenant: usuário pode acessar a companhia?
    // Custom Claim opcional `companhias`: lista de IDs permitidos.
    // Admin SEM o claim = acesso total (transição). Com o claim, filtra.
    function canAccessCia(cid) {
      return isAuth() && (
        !('companhias' in request.auth.token) ||
        (request.auth.token.companhias is list && cid in request.auth.token.companhias) ||
        isAdmin()
      );
    }

    // ════════════════════════════════════════════════════════════
    // MULTI-TENANT (novo) — /companhias/{cid}/...
    // ════════════════════════════════════════════════════════════
    match /companhias/{cid} {
      allow read:  if isAuth();         // qualquer autenticado lista companhias
      allow write: if isAdmin();        // só admin cria/edita metadata

      // Militares da companhia
      match /mils/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if isAdmin() && canAccessCia(cid);
      }

      // Operações
      match /ops/{docId} {
        allow read:   if isUser() && canAccessCia(cid);
        allow create: if isUser() && canAccessCia(cid);
        allow update: if isUser() && canAccessCia(cid);
        allow delete: if isAdmin() && canAccessCia(cid);
      }

      // Escalas
      match /escalas/{docId} {
        allow read:   if isUser() && canAccessCia(cid);
        allow create: if isUser() && canAccessCia(cid);
        allow update: if isUser() && canAccessCia(cid);
        allow delete: if isAdmin() && canAccessCia(cid);
      }

      // Dispensas
      match /dispensas/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if isUser() && canAccessCia(cid);
      }

      // Configs (vrte, usuarios, assinantes, anexo_visitas, ultimo_assinante)
      match /config/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if isAdmin() && canAccessCia(cid);
      }
      // VRTE pode ser escrito por qualquer usuário (registro de entradas/saídas)
      match /config/vrte {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if isUser() && canAccessCia(cid);
      }
    }

    // ════════════════════════════════════════════════════════════
    // LEGADO (raiz) — mantido durante a transição multi-tenant.
    // Pode ser removido após migração completa estar testada.
    // ════════════════════════════════════════════════════════════
    match /mils/{docId} {
      allow read: if isUser();
      allow write: if isAdmin();
    }
    match /ops/{docId} {
      allow read:   if isUser();
      allow create: if isUser();
      allow update: if isUser();
      allow delete: if isAdmin();
    }
    match /escalas/{docId} {
      allow read:   if isUser();
      allow create: if isUser();
      allow update: if isUser();
      allow delete: if isAdmin();
    }
    match /dispensas/{docId} {
      allow read:  if isUser();
      allow write: if isUser();
    }
    match /config/vrte {
      allow read:  if isUser();
      allow write: if isUser();
    }
    match /config/anexo_visitas {
      allow read:  if isUser();
      allow write: if isAdmin();
    }
    match /config/usuarios    { allow read: if isAuth(); allow write: if isAdmin(); }
    match /config/assinantes  { allow read, write: if isAdmin(); }
    match /config/ultimo_assinante { allow read: if isUser(); allow write: if isAdmin(); }

    // ════════════════════════════════════════════════════════════
    // GLOBAIS (não particionadas por companhia)
    // ════════════════════════════════════════════════════════════
    match /rateLimits/{docId} {
      allow read, write: if true;
    }
    match /logs/{docId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }
    // Sistema: usuários globais (com lista de companhias permitidas em Custom Claims)
    // Qualquer autenticado pode LER (sem senhas, só metadados). Só admin escreve.
    match /sistema/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Bloquear tudo que não foi explicitamente liberado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
