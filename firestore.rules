rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()        { return request.auth != null; }
    function isAdmin()       { return isAuth() && request.auth.token.role == 'admin'; }
    function isComandante()  { return isAuth() && request.auth.token.role == 'comandante'; }
    function isOperador()    { return isAuth() && request.auth.token.role == 'operador'; }
    function isVisualizador(){ return isAuth() && request.auth.token.role == 'visualizador'; }
    // Compat: roles legados (admin/colaborador antigos)
    function isColaborador() { return isAuth() && request.auth.token.role == 'colaborador'; }
    // isUser = qualquer um dos roles válidos (acesso de leitura/operação básica)
    function isUser()        { return isAdmin() || isComandante() || isOperador() || isVisualizador() || isColaborador(); }
    // canEdit = quem pode escrever dados operacionais (não inclui visualizador)
    function canEdit()       { return isAdmin() || isComandante() || isOperador() || isColaborador(); }
    // canManage = quem pode fazer ações de gestão (admin, comandante)
    function canManage()     { return isAdmin() || isComandante(); }

    // Multi-tenant: usuário pode acessar a companhia?
    // Custom Claim opcional `companhias`: lista de IDs permitidos.
    // Admin SEM o claim = acesso total (transição). Com o claim, filtra.
    function canAccessCia(cid) {
      return isAuth() && (
        !('companhias' in request.auth.token) ||
        (request.auth.token.companhias is list && cid in request.auth.token.companhias) ||
        isAdmin()
      );
    }

    // ════════════════════════════════════════════════════════════
    // MULTI-TENANT (novo) — /companhias/{cid}/...
    // ════════════════════════════════════════════════════════════
    match /companhias/{cid} {
      allow read:  if isAuth();         // qualquer autenticado lista companhias
      allow write: if isAdmin();        // só admin cria/edita metadata

      // Militares da companhia
      // Read: qualquer usuário autenticado da companhia
      // Write: Admin ou Comandante (operadores/visualizadores não cadastram)
      match /mils/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if canManage() && canAccessCia(cid);
      }

      // Operações
      // Read/create/update: qualquer não-visualizador
      // Delete: só admin
      match /ops/{docId} {
        allow read:   if isUser() && canAccessCia(cid);
        allow create: if canEdit() && canAccessCia(cid);
        allow update: if canEdit() && canAccessCia(cid);
        allow delete: if isAdmin() && canAccessCia(cid);
      }

      // Escalas
      // Create/update: qualquer não-visualizador (admin/cmt/operador)
      // Delete (cancelar): só admin/comandante
      match /escalas/{docId} {
        allow read:   if isUser() && canAccessCia(cid);
        allow create: if canEdit() && canAccessCia(cid);
        allow update: if canEdit() && canAccessCia(cid);
        allow delete: if canManage() && canAccessCia(cid);
      }

      // Escalas Extra (GSE — Guarda de Serviço Extra)
      match /escalas_extra/{docId} {
        allow read:   if isUser() && canAccessCia(cid);
        allow create: if canEdit() && canAccessCia(cid);
        allow update: if canEdit() && canAccessCia(cid);
        allow delete: if canManage() && canAccessCia(cid);
      }

      // Dispensas: criar/editar/excluir qualquer não-visualizador
      match /dispensas/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if canEdit() && canAccessCia(cid);
      }

      // Configs (usuarios, assinantes, anexo_visitas, ultimo_assinante)
      // Read: qualquer da companhia. Write: admin/comandante
      match /config/{docId} {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if canManage() && canAccessCia(cid);
      }
      // VRTE pode ser escrito por qualquer não-visualizador
      match /config/vrte {
        allow read:  if isUser() && canAccessCia(cid);
        allow write: if canEdit() && canAccessCia(cid);
      }
    }

    // ════════════════════════════════════════════════════════════
    // LEGADO (raiz) — mantido durante a transição multi-tenant.
    // Pode ser removido após migração completa estar testada.
    // ════════════════════════════════════════════════════════════
    match /mils/{docId} {
      allow read: if isUser();
      allow write: if canManage();
    }
    match /ops/{docId} {
      allow read:   if isUser();
      allow create: if canEdit();
      allow update: if canEdit();
      allow delete: if isAdmin();
    }
    match /escalas/{docId} {
      allow read:   if isUser();
      allow create: if canEdit();
      allow update: if canEdit();
      allow delete: if canManage();
    }
    match /dispensas/{docId} {
      allow read:  if isUser();
      allow write: if canEdit();
    }
    match /config/vrte {
      allow read:  if isUser();
      allow write: if canEdit();
    }
    match /config/anexo_visitas {
      allow read:  if isUser();
      allow write: if canManage();
    }
    match /config/usuarios    { allow read: if isAuth(); allow write: if isAdmin(); }
    match /config/assinantes  { allow read: if isUser(); allow write: if canManage(); }
    match /config/ultimo_assinante { allow read: if isUser(); allow write: if canManage(); }

    // ════════════════════════════════════════════════════════════
    // GLOBAIS (não particionadas por companhia)
    // ════════════════════════════════════════════════════════════
    match /rateLimits/{docId} {
      allow read, write: if true;
    }
    match /logs/{docId} {
      allow read:  if isAdmin();
      allow write: if isAuth();
    }
    // Sistema: usuários globais (com lista de companhias permitidas em Custom Claims)
    // Qualquer autenticado pode LER (sem senhas, só metadados). Só admin escreve.
    match /sistema/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Bloquear tudo que não foi explicitamente liberado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
